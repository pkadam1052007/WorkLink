@model IEnumerable<WorkLink.Models.Job>

@{
    ViewData["Title"] = "My Bookings";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    @@media (max-width: 576px) {
        table th, table td {
            font-size: 14px;
        }
    }
</style>


<div class="container py-4">
    <h3 class="mb-4 text-center text-md-start">My Bookings</h3>

    <div class="table-responsive">
        <table class="table table-bordered align-middle table-hover">
            <thead class="table-dark text-nowrap">
                <tr>
                    <th>Worker</th>
                    <th>Profession</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="text-md-end">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var job in Model)
                {
                    var alreadyReviewed =
                    job.WorkerProfile.Reviews.Any(r => r.JobId == job.JobId);

                    <tr>
                        <td class="fw-semibold">
                            @job.WorkerProfile.FullName
                        </td>

                        <td>
                            @job.WorkerProfile.Profession
                        </td>

                        <td>
                            @job.JobDate.ToString("dd MMM yyyy")
                        </td>

                        <td class="text-success fw-semibold">
                            ₹@job.TotalAmount
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                @job.Status
                            </span>
                        </td>

                        <td class="text-md-end">
                            <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">

                                @* CANCEL BOOKING *@
                                @if (job.Status == JobStatus.Requested)
                                {
                                    <form asp-controller="Jobs"
                                          asp-action="Cancel"
                                          asp-route-id="@job.JobId"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to cancel this booking?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-sm btn-danger w-100">
                                            ❌ Cancel
                                        </button>
                                    </form>
                                }

                                @* LEAVE REVIEW *@
                                @if (job.Status == JobStatus.Completed && !alreadyReviewed)
                                {
                                    <a asp-controller="Reviews"
                                       asp-action="Create"
                                       asp-route-jobId="@job.JobId"
                                       class="btn btn-sm btn-primary w-100">
                                        ⭐ Leave Review
                                    </a>
                                }
                                else if (alreadyReviewed)
                                {
                                    <span class="badge bg-success align-self-start align-self-md-center">
                                        Reviewed
                                    </span>
                                }

                                @* FALLBACK *@
                                @if (job.Status != JobStatus.Requested &&
                                                            job.Status != JobStatus.Completed &&
                                                            !alreadyReviewed)
                                {
                                    <span class="text-muted">—</span>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
