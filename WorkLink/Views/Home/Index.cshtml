@model IEnumerable<WorkLink.Models.WorkerProfile>

@{
    ViewData["Title"] = "Home Page";
}

@if (TempData["EasterEgg"] != null)
{
    <div class="alert alert-success mt-3 text-center">
        @TempData["EasterEgg"]
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .worker-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .worker-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.12);
        }

    .worker-img {
        transition: transform 0.4s ease;
    }

    .worker-card:hover .worker-img {
        transform: scale(1.05);
    }

    .rating-badge {
        font-size: 0.85rem;
        padding: 6px 12px;
        border-radius: 20px;
    }

    .search-box input {
        border-radius: 30px;
        padding-left: 16px;
    }

    .search-box button,
    .search-box a {
        border-radius: 30px;
    }
</style>

<section class="py-5 bg-white">
    <div class="container">

        <!-- 🔍 SEARCH BAR -->
        <form asp-action="Index" method="get" class="row g-2 mb-4 align-items-end search-box">

            <div class="col-12 col-md-4">
                <input type="text"
                       name="profession"
                       value="@Context.Request.Query["profession"]"
                       class="form-control"
                       placeholder="Profession (e.g. Electrician, Plumber)">
            </div>

            <div class="col-12 col-md-4">
                <input type="text"
                       name="city"
                       value="@Context.Request.Query["city"]"
                       class="form-control"
                       placeholder="City (e.g. Mumbai, Pune)">
            </div>

            <div class="col-12 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i> Search
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    Clear
                </a>
            </div>
        </form>

        <div class="text-center mb-5">
            <h2 class="fw-bold">Available Workers</h2>
            <p class="text-muted">Browse skilled professionals near you</p>
        </div>

        <div class="row g-4">
            @if (!Model.Any())
            {
                <div class="col-12 text-center text-muted">
                    <p>No workers available right now.</p>
                </div>
            }
            else
            {
                @foreach (var worker in Model)
                {
                    <div class="col-md-4">
                        <div class="card h-100 border-0 overflow-hidden worker-card">

                            <img src="@(!string.IsNullOrEmpty(worker.ProfileImageUrl)
                                                                 ? worker.ProfileImageUrl
                                                                 : "https://via.placeholder.com/400x250")"
                         class="card-img-top worker-img"
                         alt="@worker.FullName"
                         style="height: 250px; object-fit: cover;">

                            <div class="card-body">
                                <h5 class="card-title fw-bold mb-2">@worker.FullName</h5>

                                <p class="card-text mb-1 text-muted">
                                    <i class="bi bi-tools me-1"></i> @worker.Profession
                                </p>

                                <p class="card-text mb-1 text-muted">
                                    <i class="bi bi-currency-rupee me-1"></i> @worker.HourlyRate / hr
                                </p>

                                <p class="card-text mb-2 text-muted">
                                    <i class="bi bi-geo-alt me-1"></i> @worker.City
                                </p>

                                <span class="badge bg-success rating-badge">
                                    <i class="bi bi-star-fill me-1"></i>
                                    @worker.Rating / 5
                                </span>

                                <div class="mt-3 d-flex gap-2">
                                    <a asp-controller="Home"
                                       asp-action="Profile"
                                       asp-route-id="@worker.WorkerProfileId"
                                       class="btn btn-primary w-50 rounded-pill">
                                        View Profile
                                    </a>

                                    <a asp-controller="Jobs"
                                       asp-action="Create"
                                       asp-route-workerId="@worker.WorkerProfileId"
                                       class="btn btn-outline-primary w-50 rounded-pill">
                                        Hire
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                        }
            }
        </div>
    </div>
</section>
