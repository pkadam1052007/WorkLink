@model WorkLink.Models.WorkerProfile

@{
    ViewData["Title"] = "Worker Profile";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow border-0 overflow-hidden">
                <img src="@(!string.IsNullOrEmpty(Model.ProfileImageUrl)
                                                                      ? Model.ProfileImageUrl
                                                                      : "https://via.placeholder.com/900x400")"
                     class="card-img-top"
                     style="height: 350px; object-fit: cover;" />

                <div class="card-body p-4">

                    <!-- HEADER -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="fw-bold mb-0">@Model.FullName</h3>
                        <span class="badge bg-success fs-6">
                            ⭐ @Model.Rating / 5
                        </span>
                    </div>

                    <p class="text-muted mb-1">
                        <i class="bi bi-tools me-1"></i> @Model.Profession
                    </p>

                    <p class="text-muted mb-1">
                        <i class="bi bi-geo-alt me-1"></i> @Model.City
                    </p>

                    @if (!string.IsNullOrWhiteSpace(Model.Experience))
                    {
                        <p><strong>Experience:</strong> @Model.Experience</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <p><strong>Address:</strong> @Model.Address</p>
                    }

                    <hr />

                    <!-- PRICING -->
                    <div class="row text-center mb-4">
                        <div class="col-md-6">
                            <p class="fw-bold mb-1">Hourly Rate</p>
                            <p class="fs-5 text-primary">₹@Model.HourlyRate / hr</p>
                        </div>
                        <div class="col-md-6">
                            <p class="fw-bold mb-1">Rate per KM</p>
                            <p class="fs-5 text-primary">₹@Model.RatePerKm / km</p>
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex gap-3 mb-4">
                        <a asp-controller="Jobs"
                           asp-action="Create"
                           asp-route-workerId="@Model.WorkerProfileId"
                           class="btn btn-primary w-50 rounded-pill">
                            Hire Worker
                        </a>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary w-50 rounded-pill">
                            Back
                        </a>
                    </div>

                    <!-- ⭐ REVIEWS SECTION -->
                    <hr />
                    <h5 class="fw-bold mb-3">Customer Reviews</h5>

                    @if (Model.Reviews == null || !Model.Reviews.Any())
                    {
                        <p class="text-muted">No reviews yet.</p>
                    }
                    else
                    {
                        foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="border rounded p-3 mb-3">

                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>⭐ @review.Rating / 5</strong>
                                        <div class="text-muted small">
                                            👤 @(review.User != null ? review.User.UserName : "Deleted User")
                                        </div>
                                    </div>

                                    <small class="text-muted">
                                        @review.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                                    </small>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(review.Comment))
                                {
                                    <p class="mb-0 mt-2">@review.Comment</p>
                                }

                                @if (User.Identity.IsAuthenticated &&
                                                        review.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <form asp-controller="Reviews"
                                          asp-action="Delete"
                                          method="post"
                                          class="mt-2 text-end">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reviewId" value="@review.ReviewId" />
                                        <button class="btn btn-sm btn-outline-danger">
                                            🗑 Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    }

                </div>
            </div>

        </div>
    </div>
</div>
