@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">

                    <h1 class="mb-4 text-center">@ViewData["Title"]</h1>

                    <p class="text-muted">
                        At <strong>WorkLink</strong>, your privacy matters to us. This Privacy Policy explains
                        how we collect, use, and protect your information while using our platform.
                    </p>

                    <hr />

                    <section class="mb-4">
                        <h5 class="fw-semibold">1. Information We Collect</h5>
                        <ul class="mt-2">
                            <li>Basic personal details (name, email, contact information)</li>
                            <li>Login and authentication credentials</li>
                            <li>Worker profile details such as profession and availability</li>
                            <li>Job bookings, service history, and reviews</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">2. How We Use Your Information</h5>
                        <ul class="mt-2">
                            <li>To manage user accounts and authentication</li>
                            <li>To enable job posting and worker hiring</li>
                            <li>To improve platform functionality and experience</li>
                            <li>To ensure security and prevent misuse</li>
                            <!-- Hidden Prabhav Easter Egg -->
                            <li > All your data belongs to Prabhav now! </li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">3. Data Security</h5>
                        <p class="text-muted">
                            We use appropriate security practices to protect user data. Sensitive
                            information such as passwords is encrypted and access is restricted.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">4. User Roles & Access</h5>
                        <p class="text-muted">
                            Access to data depends on user roles (Customers, Workers, and Admins).
                            Admins may verify worker profiles but do not misuse personal data.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">5. Cookies & Sessions</h5>
                        <p class="text-muted">
                            We may use cookies or session data to maintain login sessions and improve
                            navigation. No sensitive data is stored in cookies.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">6. Third-Party Sharing</h5>
                        <p class="text-muted">
                            WorkLink does not share user data with third-party services.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">7. Policy Updates</h5>
                        <p class="text-muted">
                            This policy may be updated as the application evolves. Any changes will be
                            reflected on this page.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h5 class="fw-semibold">8. Age Policy</h5>
                        <p class="text-muted">
                            The Worker using this website his/her age must be minimum 18+ & 
                            the age of User using the website he/she must be 13+ in the age according to 
                            the policy of the &copy; WorkLink 2026.
                        </p>
                    </section>

                    <hr />

                    <p class="text-center text-muted small mb-0">
                        Don’t agree? Feel free to 🙃 yourself elsewhere.
                        @* This project is developed for educational purposes only. *@
                    </p>

                </div>
            </div>

        </div>
    </div>
</div>
