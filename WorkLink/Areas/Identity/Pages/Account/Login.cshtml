@page
@model WorkLink.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        min-height: 100vh;
        background: linear-gradient(180deg, #eef2ff 0%, #f8f9ff 60%, #ffffff 100%);
        font-family: 'Segoe UI', sans-serif;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        padding: 30px 26px;
    }

    .logo {
        text-align: center;
        margin-bottom: 16px;
        font-size: 26px;
        font-weight: 700;
        color: #2c5be3;
    }

    .welcome-text {
        text-align: center;
        margin-bottom: 24px;
    }

        .welcome-text h4 {
            font-weight: 700;
            margin-bottom: 4px;
        }

        .welcome-text p {
            font-size: 14px;
            color: #6c757d;
        }

    .role-toggle {
        display: flex;
        background: #f1f1f1;
        border-radius: 50px;
        padding: 4px;
        margin-bottom: 20px;
    }

        .role-toggle button {
            flex: 1;
            border: none;
            background: transparent;
            padding: 10px 0;
            border-radius: 50px;
            font-weight: 600;
            color: #6c757d;
            cursor: pointer;
        }

        .role-toggle .active {
            background: #6f6af8;
            color: #fff;
        }

    .form-control {
        border-radius: 14px;
        height: 52px;
        padding-left: 16px;
    }

    .login-btn {
        background: #c9c4ff;
        border: none;
        border-radius: 30px;
        height: 52px;
        font-weight: 600;
        color: #fff;
    }

        .login-btn:hover {
            background: #6f6af8;
        }

    .forgot-link {
        font-size: 14px;
        text-align: right;
        display: block;
        margin-bottom: 16px;
    }

    .signup-text {
        text-align: center;
        font-size: 14px;
        margin-top: 24px;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">

        <div class="logo">WorkLink</div>

        <div class="welcome-text">
            <h4>Welcome Back</h4>
            <p>Login to your account</p>
        </div>

        <!-- ROLE TOGGLE -->
        <div class="role-toggle">
            <button type="button" id="userBtn" class="active">I'm a User</button>
            <button type="button" id="workerBtn">I'm a Worker</button>
        </div>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-2"></div>

            <!-- ✅ ROLE VALUE -->
            <input type="hidden" name="SelectedRole" id="SelectedRole" value="User" />

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="Email or Phone" />
                <label asp-for="Input.Email">Email or Phone</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <a asp-page="./ForgotPassword" class="forgot-link">Forgot Password?</a>

            <button type="submit" class="btn login-btn w-100">
                Login
            </button>
        </form>

        <div class="signup-text">
            Don't have an account?
            <a asp-page="./Register">Sign Up</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const userBtn = document.getElementById("userBtn");
        const workerBtn = document.getElementById("workerBtn");
        const roleInput = document.getElementById("SelectedRole");

        userBtn.onclick = () => {
            userBtn.classList.add("active");
            workerBtn.classList.remove("active");
            roleInput.value = "User";
        };

        workerBtn.onclick = () => {
            workerBtn.classList.add("active");
            userBtn.classList.remove("active");
            roleInput.value = "Worker";
        };
    </script>
}
